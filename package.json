{
  "name": "@sailingnaturali/station-corrections",
  "version": "2.3.0",
  "description": "Friendly names, search aliases and corrected positions for tide and current stations",
  "main": "src/index.js",
  "types": "index.d.ts",
  "scripts": {
    "test": "node --test && npm run test:types",
    "test:types": "tsc -p tsconfig.json",
    "build:data": "node scripts/build-data.mjs",
    "check:data": "npm run build:data && git diff --exit-code data/corrections.json data/registry.json"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sailingnaturali/station-corrections.git"
  },
  "keywords": [
    "tides",
    "currents",
    "stations",
    "noaa",
    "chs",
    "geocoding",
    "corrections"
  ],
  "author": "Sailing Naturali",
  "license": "MIT",
  "type": "module",
  "bugs": {
    "url": "https://github.com/sailingnaturali/station-corrections/issues"
  },
  "homepage": "https://github.com/sailingnaturali/station-corrections#readme",
  "dependencies": {
    "@turf/boolean-point-in-polygon": "^7.3.5",
    "@turf/helpers": "^7.3.5",
    "yaml": "^2.9.0"
  },
  "bin": {
    "station-corrections": "bin/station-corrections.mjs"
  },
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "default": "./src/index.js"
    },
    "./data/*": "./data/*",
    "./validate-positions": {
      "types": "./validate-positions.d.ts",
      "default": "./src/validate-positions.js"
    }
  },
  "//sideEffects": "No module here does anything observable at import time, so an unused one is safe to drop. That is what lets a bundler strip loadCorrections - and with it the yaml parser - from an app that only calls createBundledResolver, and strip the coastline parse from one that never validates positions.",
  "sideEffects": false,
  "files": [
    "src",
    "bin",
    "data",
    "index.d.ts",
    "validate-positions.d.ts",
    "PROVENANCE.md",
    "!**/*.test.js",
    "!**/*.test.mjs"
  ],
  "devDependencies": {
    "typescript": "^7.0.2"
  }
}
