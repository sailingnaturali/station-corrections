{
  "//": "Type-checks the shipped declarations against consumer-shaped usage. Emits nothing - this package is plain JS.",
  "compilerOptions": {
    "target": "es2022",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "strict": true,
    "allowJs": true,
    "noUnusedLocals": true,
    "noEmit": true,
    "skipLibCheck": true
  },
  "include": ["types/**/*.ts", "index.d.ts", "validate-positions.d.ts"]
}
